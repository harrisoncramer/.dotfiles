{
  "hooks": {
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "[ -n \"$MAIN_SESSION\" ] && tmux -L default set -t \"$MAIN_SESSION\" @claude_status \" #[fg=#FF9E3B]thinking \" 2>/dev/null || true"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "[ -n \"$MAIN_SESSION\" ] && tmux -L default set -t \"$MAIN_SESSION\" @claude_status \" #[fg=#7E9CD8]-- \" 2>/dev/null || true"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "wt list statusline --format=claude-code"
  },
  "enabledPlugins": {
    "worktrunk@worktrunk": true
  },
  "extraKnownMarketplaces": {
    "worktrunk": {
      "source": {
        "source": "github",
        "repo": "max-sixty/worktrunk"
      }
    }
  },
  "skipDangerousModePermissionPrompt": true
}
