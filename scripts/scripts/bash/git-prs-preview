#!/bin/zsh

repo="$1"
num="$2"
tmpfile="/tmp/git-prs-preview-$num.md"

gh pr view "$num" --repo "$repo" --json title,body,reviewDecision,reviews,statusCheckRollup \
  | jq -r '
    (if .reviewDecision == "APPROVED" then "✅ Approved"
     elif .reviewDecision == "CHANGES_REQUESTED" then "🔴 Needs Work"
     elif .reviewDecision == "REVIEW_REQUIRED" then "👀 In Review"
     else "🔧 In Development" end) as $st |

    (.reviews
     | map(select(.state != "COMMENTED"))
     | group_by(.author.login)
     | map(sort_by(.submittedAt) | last)
     | map(
         (if .state == "APPROVED" then "✅"
          elif .state == "CHANGES_REQUESTED" then "🔴"
          else "👀" end) + " " + .author.login)
     | join("\n")) as $revs |

    (.statusCheckRollup
     | if . == null or length == 0 then "No checks"
       else map(
         (if .conclusion == "SUCCESS" then "✅"
          elif .conclusion == "FAILURE" then "❌"
          elif .status == "IN_PROGRESS" then "🔄"
          else "⏳" end) + " " + .name)
       | join("\n") end) as $checks |

    "# " + .title + "\n\n" +
    (.body // "No description") + "\n\n" +
    "---\n\n" +
    "## Status: " + $st + "\n\n" +
    $revs + "\n\n" +
    "## Checks\n\n" +
    $checks
  ' > "$tmpfile"

bat --style=plain --color=always --language=markdown "$tmpfile"
