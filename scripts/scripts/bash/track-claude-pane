#!/bin/bash
# Scan all tmux panes to find one running claude and store its pane ID in @claude_last_pane.
found=""
while IFS=: read -r pane_id pane_tty; do
    if ps -o comm= -t "$pane_tty" 2>/dev/null | grep -qE "^claude$"; then
        found="$pane_id"
        break
    fi
done < <(tmux list-panes -a -F '#{pane_id}:#{pane_tty}')

if [ -n "$found" ]; then
    tmux set-option -g @claude_last_pane "$found"
fi
