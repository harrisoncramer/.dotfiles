#!/bin/zsh
set -euo pipefail

# DMs the PR author via Slack to let them know you left a review.
# Called from git-reviews via C-s.
# Requires SLACK_USER_TOKEN and GITHUB_TO_SLACK in ~/.zshrc-work.
# Usage: git-reviews-slack <author-gh-login> <pr-url>

source "$HOME/.zshrc-work" 2>/dev/null || true

# TODO: uncomment to use real author
# GH_USER="$1"
GH_USER="harrisoncramer"
URL="$2"

if [[ -z "${SLACK_USER_TOKEN:-}" ]]; then
  echo "Error: SLACK_USER_TOKEN not set" >&2
  exit 1
fi

if [[ -z "${(k)GITHUB_TO_SLACK[@]:-}" ]]; then
  echo "Error: GITHUB_TO_SLACK not set" >&2
  exit 1
fi

slack_id="${GITHUB_TO_SLACK[$GH_USER]:-""}"
if [[ -z "$slack_id" ]]; then
  echo "Error: No Slack ID found for $GH_USER" >&2
  exit 1
fi

PHRASES=(
  "left some comments on this"
  "just finished reviewing this"
  "took a look, left some thoughts"
  "dropped some feedback on this"
  "had a look, left a few notes"
  "review's up on this one"
  "left a review"
  "gave this a pass"
)

IDX=$((RANDOM % ${#PHRASES[@]}))
MSG="${PHRASES[$IDX]} $URL"

CHANNEL=$(curl -s -X POST "https://slack.com/api/conversations.open" \
  -H "Authorization: Bearer $SLACK_USER_TOKEN" \
  -H "Content-Type: application/json" \
  -d "{\"users\": \"$slack_id\"}" | jq -r '.channel.id')

if [[ -n "$CHANNEL" && "$CHANNEL" != "null" ]]; then
  curl -s -X POST "https://slack.com/api/chat.postMessage" \
    -H "Authorization: Bearer $SLACK_USER_TOKEN" \
    -H "Content-Type: application/json" \
    -d "{\"channel\": \"$CHANNEL\", \"text\": \"$MSG\"}" > /dev/null
fi

gum log --level info "Notified @$GH_USER"
