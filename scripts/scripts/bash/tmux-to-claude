#!/bin/bash

# Capture tmux pane output and send to Claude

if ! tmux info &>/dev/null; then
  echo "Error: Not running inside tmux"
  exit 1
fi

# Number of lines to capture (can be overridden with -n flag)
LINES=1000

while getopts "n:" opt; do
  case $opt in
    n) LINES=$OPTARG ;;
    *) echo "Usage: $0 [-n lines]" ; exit 1 ;;
  esac
done

TMPFILE=$(mktemp /tmp/tmux-output.XXXXXX)

# Capture pane and look for the last prompt pattern
# This searches backwards for a line that looks like a prompt (contains git branch info)
tmux capture-pane -p -S -"$LINES" |
  awk '/.*  (main|master|[a-zA-Z0-9_-]+)  .*/ {start=NR} {lines[NR]=$0} END {if(start) for(i=start+1;i<=NR;i++) print lines[i]}' > "$TMPFILE"

# Check if we captured anything
if [[ ! -s "$TMPFILE" ]]; then
  echo "No output captured. Try increasing lines with -n flag"
  rm "$TMPFILE"
  exit 1
fi

# Send to Claude
claude "$TMPFILE"

# Cleanup
rm "$TMPFILE"
