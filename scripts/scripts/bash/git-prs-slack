#!/bin/zsh
set -euo pipefail

# DMs PR reviewers via Slack asking them to take a look.
# Called from git-prs via C-s. Tracks bumped PRs in /tmp/git-prs-bumped.
# Requires SLACK_USER_TOKEN and GITHUB_TO_SLACK in ~/.zshrc-work.
# E.g. 
# typeset -A GITHUB_TO_SLACK
# GITHUB_TO_SLACK=(
# [harrisoncramer]='U123'
# )
#
# Usage: git-prs-slack <repo> <pr-number> <pr-url>

source "$HOME/.zshrc-work" 2>/dev/null || true

REPO="$1"
NUM="$2"
URL="$3"

if [[ -z "${SLACK_USER_TOKEN:-}" ]]; then
  echo "Error: SLACK_USER_TOKEN not set" >&2
  exit 1
fi

if [[ -z "${(k)GITHUB_TO_SLACK[@]:-}" ]]; then
  echo "Error: GITHUB_TO_SLACK not set" >&2
  exit 1
fi

REVIEWERS=$(gh pr view "$NUM" --repo "$REPO" --json reviewRequests --jq '.reviewRequests[].login')

if [[ -z "$REVIEWERS" ]]; then
  exit 0
fi

PHRASES=(
  "hey, do you mind taking a look at this"
  "would love your eyes on this when you have a sec"
  "do you mind giving this a review?"
  "got a sec to review this?"
  "hey hey, appreciate a review here when you have a sec"
  "could you take a peek at this?"
  "this is ready when you have a moment"
  "no rush, would love a review here"
  "let me know your thoughts when you get a chance"
  "would you mind reviewing this?"
  "feedback appreciated whenever you're free"
  "please review when convenient"
  "take your time, but a review would be great"
)

for gh_user in $REVIEWERS; do
  slack_id="${GITHUB_TO_SLACK[$gh_user]:-""}"
  if [[ -z "$slack_id" ]]; then
    continue
  fi

  IDX=$((RANDOM % ${#PHRASES[@]}))
  MSG="${PHRASES[$IDX]} $URL"

  CHANNEL=$(curl -s -X POST "https://slack.com/api/conversations.open" \
    -H "Authorization: Bearer $SLACK_USER_TOKEN" \
    -H "Content-Type: application/json" \
    -d "{\"users\": \"$slack_id\"}" | jq -r '.channel.id')

  if [[ -n "$CHANNEL" && "$CHANNEL" != "null" ]]; then
    curl -s -X POST "https://slack.com/api/chat.postMessage" \
      -H "Authorization: Bearer $SLACK_USER_TOKEN" \
      -H "Content-Type: application/json" \
      -d "{\"channel\": \"$CHANNEL\", \"text\": \"$MSG\"}" > /dev/null
  fi
done

BUMPS_FILE="/tmp/git-prs-bumped"
touch "$BUMPS_FILE"
if ! grep -qx "$REPO:$NUM" "$BUMPS_FILE"; then
  echo "$REPO:$NUM" >> "$BUMPS_FILE"
fi

gum log --level info "Sent slack bump for PR #$NUM"
