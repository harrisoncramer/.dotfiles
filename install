#!/bin/bash
set -eu -o pipefail

# Source common utility functions
source "./utils"

# Flags
NPM=false
GO=false
CLAUDE=false
HOMEBREW=false
NVIM=false
TMUX=false
MISE=false

# ----------------------
# Homebrew install location
# ----------------------
BREW_PREFIX="$HOME/homebrew"
export PATH="$BREW_PREFIX/bin:$HOME/.local/bin:$PATH"

# Ensure local bin exists
mkdir -p "$HOME/.local/bin"

# ----------------------
# Usage function
# ----------------------
function usage() {
  echo "Usage: ./install [OPTIONS]
Installs dependencies for my development environment.

Options:
  --all     Installs all dependencies
  --brew    Installs brew dependencies (required for other installs)
  --go      Installs Go packages
  --npm     Installs NPM packages
  --mise    Installs languages/tools through Mise
  --claude  Configures Claude
  --nvim    Installs Neovim
  --tmux    Installs TPM for tmux
  --help    Prints this help
"
}

# ----------------------
# Parse command line options
# ----------------------
while test $# != 0; do
  case "$1" in
  --all)
    HOMEBREW=true
    GO=true
    NPM=true
    NVIM=true
    MISE=true
    CLAUDE=true
    ;;
  --claude) CLAUDE=true ;;
  --brew) HOMEBREW=true ;;
  --nvim) NVIM=true ;;
  --go) GO=true ;;
  --mise) MISE=true ;;
  --npm) NPM=true ;;
  --tmux) TMUX=true ;;
  --help)
    usage
    exit 0
    ;;
  *)
    usage
    exit 1
    ;;
  esac
  shift
done

# ----------------------
# Homebrew installation (skip if already installed)
# ----------------------
if $HOMEBREW; then
  if ! command -v brew &>/dev/null; then
    echo "Installing Homebrew to $BREW_PREFIX..."
    git clone https://github.com/Homebrew/brew "$BREW_PREFIX"
    export PATH="$BREW_PREFIX/bin:$PATH"
  fi
  echo "Updating Homebrew..."
  brew update
fi

# ----------------------
# Install stow and Mise via Homebrew
# ----------------------
if ! command -v stow &>/dev/null && $HOMEBREW; then
  echo "Installing stow..."
  brew install stow
fi

if ! command -v mise &>/dev/null && $HOMEBREW; then
  echo "Installing mise..."
  brew install mise
fi

if $MISE; then
  echo "Installing languages/tools through Mise..."
  linker "$(pwd)/mise.toml" ~/mise.toml
  mise trust -q
  mise install
fi

# ----------------------
# Prepare dotfiles & local config
# ----------------------
touch ~/.zshrc-personal
mkdir -p ~/.local/bin
linker "$(pwd)/.hushlogin" ~/.hushlogin

HOST_NAME=$(hostname)

# ----------------------
# Stow directories (skip Homebrew to avoid conflicts)
# ----------------------
for dir in "$(pwd)"/*/; do
  DIR_ROOT="${dir%*/}"
  DIR_NAME="${DIR_ROOT##*/}"
  echo "Configuring ${DIR_NAME}..."

  case $DIR_NAME in
  deps)
    echo "Processing deps..."
    for dep_dir in "$DIR_ROOT"/*; do
      dep_name=$(basename "$dep_dir")
      if [ "$dep_name" = "homebrew" ]; then
        echo "Skipping stow for Homebrew"
        continue
      fi
      if [ -d "$dep_dir" ]; then
        stow -t "$HOME" "deps/$dep_name"
        echo "  stowed deps/$dep_name"
      fi
    done
    ;;
  git)
    linker "$(pwd)/git/.gitignore" ~/.gitignore
    git config --global core.excludesfile ~/.gitignore
    if [ "$HOST_NAME" = "work-computer" ]; then
      linker "$(pwd)/git/.gitconfig-work" ~/.gitconfig
    else
      linker "$(pwd)/git/.gitconfig" ~/.gitconfig
    fi
    git init
    ;;
  zsh)
    ZSH_DIR="$HOME/.oh-my-zsh"
    cloneOrUpdate https://github.com/ohmyzsh/ohmyzsh.git "$ZSH_DIR"
    cloneOrUpdate https://github.com/zsh-users/zsh-syntax-highlighting.git "$ZSH_DIR/custom/plugins/zsh-syntax-highlighting"
    cloneOrUpdate https://github.com/zsh-users/zsh-autosuggestions.git "$ZSH_DIR/custom/plugins/zsh-autosuggestions"
    cloneOrUpdate https://github.com/romkatv/powerlevel10k.git "$ZSH_DIR/themes/powerlevel10k"
    stow -t "$HOME" "$DIR_NAME"
    ;;
  claude)
    mkdir -p ~/.claude
    linker "$(pwd)/claude/settings.json" ~/.claude/settings.json
    linker "$(pwd)/claude/CLAUDE.md" ~/.claude/CLAUDE.md
    linker "$(pwd)/claude/skills" ~/.claude/skills
    ;;
  *)
    stow -t "$HOME" "$DIR_NAME"
    ;;
  esac
done

# ----------------------
# Install Neovim locally
# ----------------------
if $NVIM; then
  ./nvim-install
fi

# ----------------------
# TPM for tmux
# ----------------------
if $TMUX; then
  mkdir -p ~/.tmux/plugins
  TPM_DIR="$HOME/.tmux/plugins/tpm"
  echo "hi"
  cloneOrUpdate https://github.com/tmux-plugins/tpm.git "$TPM_DIR"
fi

# ----------------------
# Go packages
# ----------------------
if $GO; then
  while IFS= read -r PACKAGE; do
    go install "$PACKAGE"
  done <deps/golang
fi

# ----------------------
# NPM packages
# ----------------------
if $NPM; then
  while IFS= read -r PACKAGE; do
    npm i -g "$PACKAGE"
  done <deps/npm
fi

# ----------------------
# Claude Code
# ----------------------
if $CLAUDE; then
  npm i -g @anthropic-ai/claude-code
  npm i -g claude-code-acp
fi

echo "✅ Installation complete. Homebrew is at $BREW_PREFIX, everything else in your home directory."
